# =============================================================================
# Kafka Cluster Configuration
# For production: move secrets to Vault/AWS Secrets Manager
# =============================================================================

# Confluent Platform version — pin to exact version in production
CONFLUENT_PLATFORM_VERSION=7.7.1

# KRaft Cluster ID — generated once per cluster lifetime
# To regenerate: docker run --rm confluentinc/cp-kafka:7.7.1 kafka-storage random-uuid
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk

# Replication & Durability
KAFKA_DEFAULT_REPLICATION_FACTOR=3
KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=3
KAFKA_TRANSACTION_STATE_LOG_REPLICATION_FACTOR=3
KAFKA_MIN_INSYNC_REPLICAS=2
KAFKA_TRANSACTION_STATE_LOG_MIN_ISR=2

# Performance
KAFKA_NUM_PARTITIONS=6
KAFKA_LOG_RETENTION_HOURS=168        # 7 days local; prod: 8760 (1yr) for HIPAA
KAFKA_LOG_SEGMENT_BYTES=1073741824   # 1 GB
KAFKA_LOG_RETENTION_CHECK_INTERVAL_MS=300000

# Topic governance
KAFKA_AUTO_CREATE_TOPICS_ENABLE=false
KAFKA_DELETE_TOPIC_ENABLE=true

# Schema Registry
SCHEMA_REGISTRY_PORT=8081

# Kafka UI
KAFKA_UI_PORT=8080

# JMX (metrics scraping for Prometheus in prod)
BROKER1_JMX_PORT=9101
BROKER2_JMX_PORT=9102
BROKER3_JMX_PORT=9103