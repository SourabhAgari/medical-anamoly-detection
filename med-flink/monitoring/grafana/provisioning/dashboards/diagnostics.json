{
  "uid": "med-flink-diagnostics",
  "title": "Med-Flink Diagnostics",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "logs",
      "title": "Error Logs",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{job=\"med-flink\"} | json | level=\"ERROR\"",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "options": { "showTime": true, "showLabels": true, "showCommonLabels": false, "wrapLogMessage": true, "sortOrder": "Descending", "dedupStrategy": "none", "enableLogDetails": true }
    },
    {
      "id": 2,
      "type": "logs",
      "title": "All Logs (last 15m)",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{job=\"med-flink\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "options": { "showTime": true, "showLabels": true, "showCommonLabels": false, "wrapLogMessage": true, "sortOrder": "Descending", "dedupStrategy": "none", "enableLogDetails": true }
    }
  ]
}